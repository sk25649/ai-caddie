{
  "expo": {
    "name": "AI Caddie",
    "slug": "ai-caddie",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ai-caddie",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a1a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aicaddie.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "UIBackgroundModes": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a1a0a"
      },
      "package": "com.aicaddie.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-haptics"
    ]
  }
}
